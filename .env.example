# Пример файла переменных окружения
# Скопируйте в .env и заполните своими значениями

DB_HOST=mysql
DB_USER=appuser
DB_PASSWORD=apppassword
DB_NAME=procurement_db
DB_PORT=3306

# ─── БД Goszakup (источник лотов, только чтение) ────────────────────────────
# Если БД Goszakup на том же сервере — достаточно указать только GOSZAKUP_DB_NAME
# Остальные параметры по умолчанию берутся из DB_* выше
GOSZAKUP_DB_HOST=mysql
GOSZAKUP_DB_USER=appuser
GOSZAKUP_DB_PASSWORD=apppassword
GOSZAKUP_DB_NAME=goszakup
GOSZAKUP_DB_PORT=3306


# Сколько лотов импортировать за один запуск (каждые 30 минут)
GOSZAKUP_IMPORT_BATCH_SIZE=20000
